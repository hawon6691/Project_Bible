generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  SELLER
  ADMIN

  @@map("user_role")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED

  @@map("user_status")
}

enum ProductStatus {
  ON_SALE
  SOLD_OUT
  HIDDEN

  @@map("product_status")
}

enum ShippingType {
  FREE
  PAID
  CONDITIONAL

  @@map("shipping_type")
}

enum SpecInputType {
  TEXT
  NUMBER
  SELECT

  @@map("spec_input_type")
}

enum SpecDataType {
  NUMBER
  STRING
  BOOLEAN

  @@map("spec_data_type")
}

enum OrderStatus {
  PENDING
  PAYMENT_CONFIRMED
  PREPARING
  SHIPPED
  DELIVERED
  CANCELED
  REFUNDED

  @@map("order_status")
}

enum PaymentMethod {
  CARD
  BANK_TRANSFER
  KAKAO_PAY
  NAVER_PAY
  TOSS

  @@map("payment_method")
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED

  @@map("payment_status")
}

enum PointType {
  EARN
  USE
  REFUND
  EXPIRE
  ADMIN_GRANT

  @@map("point_type")
}

enum TicketCategory {
  ORDER
  PAYMENT
  DELIVERY
  ACCOUNT
  OTHER

  @@map("ticket_category")
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED

  @@map("ticket_status")
}

enum FaqCategory {
  GENERAL
  ORDER
  PAYMENT
  DELIVERY
  ACCOUNT

  @@map("faq_category")
}

enum RecommendationType {
  TODAY
  EDITOR_PICK
  NEW_ARRIVAL

  @@map("recommendation_type")
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  BLOCKED

  @@map("friendship_status")
}

enum MappingStatus {
  PENDING
  APPROVED
  REJECTED

  @@map("mapping_status")
}

enum FraudStatus {
  PENDING
  APPROVED
  REJECTED

  @@map("fraud_status")
}

enum BuildPurpose {
  GAMING
  OFFICE
  DESIGN
  DEVELOPMENT
  STREAMING

  @@map("build_purpose")
}

enum AuctionStatus {
  OPEN
  CLOSED
  CANCELLED
  COMPLETED

  @@map("auction_status")
}

enum CarType {
  SEDAN
  SUV
  HATCHBACK
  TRUCK
  VAN
  EV

  @@map("car_type")
}

enum LeaseType {
  RENT
  LEASE
  FINANCE

  @@map("lease_type")
}

enum PartType {
  CPU
  MOTHERBOARD
  RAM
  GPU
  SSD
  HDD
  PSU
  CASE
  COOLER
  MONITOR

  @@map("part_type")
}

enum VerificationType {
  SIGNUP
  PASSWORD_RESET

  @@map("verification_type")
}

enum PriceTrend {
  RISING
  FALLING
  STABLE

  @@map("price_trend")
}

enum BuyRecommendation {
  BUY_NOW
  BUY_SOON
  WAIT
  HOLD

  @@map("buy_recommendation")
}

enum TrustTrend {
  IMPROVING
  STABLE
  DECLINING

  @@map("trust_trend")
}

enum BadgeType {
  AUTO
  MANUAL

  @@map("badge_type")
}

enum BadgeRarity {
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY

  @@map("badge_rarity")
}

model User {
  id                   Int                @id @default(autoincrement())
  email                String             @unique @db.VarChar(255)
  password             String             @db.VarChar(255)
  name                 String             @db.VarChar(50)
  phone                String             @db.VarChar(20)
  role                 UserRole           @default(USER)
  status               UserStatus         @default(ACTIVE)
  emailVerified        Boolean            @default(false) @map("email_verified")
  emailVerifiedAt      DateTime?          @map("email_verified_at")
  nickname             String             @unique @db.VarChar(30)
  bio                  String?            @db.VarChar(200)
  profileImageUrl      String?            @map("profile_image_url") @db.VarChar(500)
  searchHistoryEnabled Boolean            @default(true) @map("search_history_enabled")
  point                Int                @default(0)
  preferredLocale      String             @default("ko") @map("preferred_locale") @db.VarChar(5)
  preferredCurrency    String             @default("KRW") @map("preferred_currency") @db.VarChar(3)
  refreshToken         String?            @map("refresh_token") @db.VarChar(500)
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @default(now()) @map("updated_at")
  deletedAt            DateTime?          @map("deleted_at")
  addresses            Address[]
  orders               Order[]
  reviews              Review[]
  wishlistItems        Wishlist[]
  cartItems            CartItem[]
  priceAlerts          PriceAlert[]
  pointTransactions    PointTransaction[]
  posts                Post[]
  comments             Comment[]
  inquiries            Inquiry[]         @relation("InquiryAuthor")
  answeredInquiries    Inquiry[]         @relation("InquiryAnsweredBy")
  supportTickets       SupportTicket[]
  ticketReplies        TicketReply[]
  recentProductViews   RecentProductView[]
  searchHistories      SearchHistory[]
  pushSubscriptions    PushSubscription[]
  pushPreference       PushPreference?
  userBadges           UserBadge[]       @relation("UserBadgeOwner")
  grantedUserBadges    UserBadge[]       @relation("UserBadgeGrantedBy")
  createdChatRooms     ChatRoom[]        @relation("ChatRoomCreatedBy")
  chatMessages         ChatMessage[]     @relation("ChatMessageSender")
  chatRoomMembers      ChatRoomMember[]
  searchLogs           SearchLog[]
  searchRecentKeywords SearchRecentKeyword[]
  adminSettingsUpdated AdminSetting[]
  sentFriendRequests   Friendship[]      @relation("FriendRequester")
  receivedFriendRequests Friendship[]    @relation("FriendAddressee")
  blockedUsers         FriendBlock[]     @relation("FriendBlockOwner")
  blockedByUsers       FriendBlock[]     @relation("FriendBlockedUser")
  friendActivities     FriendActivity[]
  shortforms           Shortform[]
  shortformLikes       ShortformLike[]
  shortformComments    ShortformComment[]
  mediaAssets          MediaAsset[]
  reviewedMappings     ProductMapping[]
  emailVerifications   EmailVerification[]
  reviewedFraudAlerts  FraudAlert[]
  sellerReviews        SellerReview[]
  pcBuilds             PcBuild[]
  auctions             Auction[]

  @@index([status], map: "idx_users_status")
  @@index([role], map: "idx_users_role")
  @@map("users")
}

model Category {
  id          Int        @id @default(autoincrement())
  name        String     @db.VarChar(50)
  parentId    Int?       @map("parent_id")
  sortOrder   Int        @default(0) @map("sort_order")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @default(now()) @map("updated_at")
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  products    Product[]
  specs       SpecDefinition[]
  searchLogs  SearchLog[]
  queryViews  ProductQueryView[]
  auctions    Auction[]

  @@index([parentId], map: "idx_categories_parent")
  @@map("categories")
}

model Product {
  id              Int            @id @default(autoincrement())
  name            String         @db.VarChar(200)
  description     String
  price           Int
  discountPrice   Int?           @map("discount_price")
  stock           Int            @default(0)
  status          ProductStatus  @default(ON_SALE)
  categoryId      Int            @map("category_id")
  thumbnailUrl    String?        @map("thumbnail_url") @db.VarChar(500)
  lowestPrice     Int?           @map("lowest_price")
  sellerCount     Int            @default(0) @map("seller_count")
  viewCount       Int            @default(0) @map("view_count")
  reviewCount     Int            @default(0) @map("review_count")
  averageRating   Decimal        @default(0.0) @map("average_rating") @db.Decimal(2, 1)
  salesCount      Int            @default(0) @map("sales_count")
  popularityScore Decimal        @default(0) @map("popularity_score") @db.Decimal(10, 2)
  version         Int            @default(1)
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @default(now()) @map("updated_at")
  deletedAt       DateTime?      @map("deleted_at")
  category        Category       @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  options         ProductOption[]
  images          ProductImage[]
  specs           ProductSpec[]
  priceEntries    PriceEntry[]
  priceHistory    PriceHistory[]
  pricePredictions PricePrediction[]
  crawlerRuns      CrawlerRun[]
  priceAlerts     PriceAlert[]
  cartItems       CartItem[]
  reviews         Review[]
  wishlistItems   Wishlist[]
  inquiries       Inquiry[]
  recentViews     RecentProductView[]
  recommendations Recommendation[]
  deals           Deal[]
  dealProducts    DealProduct[]
  shortformProducts ShortformProduct[]
  newsProducts      NewsProduct[]
  approvedMappings  ProductMapping[]
  fraudAlerts       FraudAlert[]
  usedPrices        UsedPrice[]
  buildParts        BuildPart[]
  pcBuildParts      PcBuildPart[]
  compareItems      CompareItem[]
  queryView         ProductQueryView?

  @@index([categoryId], map: "idx_products_category")
  @@index([status], map: "idx_products_status")
  @@index([lowestPrice], map: "idx_products_lowest_price")
  @@index([viewCount(sort: Desc)], map: "idx_products_view_count")
  @@index([popularityScore], map: "idx_products_popularity")
  @@map("products")
}

model ProductOption {
  id        Int      @id @default(autoincrement())
  productId Int      @map("product_id")
  name      String   @db.VarChar(50)
  values    Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([productId], map: "idx_product_options_product")
  @@map("product_options")
}

model ProductImage {
  id             Int       @id @default(autoincrement())
  productId      Int       @map("product_id")
  url            String    @db.VarChar(500)
  isMain         Boolean   @default(false) @map("is_main")
  sortOrder      Int       @default(0) @map("sort_order")
  imageVariantId Int?      @map("image_variant_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  product        Product   @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([productId], map: "idx_product_images_product")
  @@map("product_images")
}

model SpecDefinition {
  id           Int           @id @default(autoincrement())
  categoryId   Int           @map("category_id")
  name         String        @db.VarChar(50)
  type         SpecInputType
  options      Json?
  unit         String?       @db.VarChar(20)
  isComparable Boolean       @default(true) @map("is_comparable")
  dataType     SpecDataType  @default(STRING) @map("data_type")
  sortOrder    Int           @default(0) @map("sort_order")
  createdAt    DateTime      @default(now()) @map("created_at")
  category     Category      @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  productSpecs ProductSpec[]
  specScores   SpecScore[]

  @@index([categoryId], map: "idx_spec_definitions_category")
  @@map("spec_definitions")
}

model ProductSpec {
  id               Int            @id @default(autoincrement())
  productId        Int            @map("product_id")
  specDefinitionId Int            @map("spec_definition_id")
  value            String         @db.VarChar(200)
  numericValue     Decimal?       @map("numeric_value") @db.Decimal(10, 2)
  createdAt        DateTime       @default(now()) @map("created_at")
  product          Product        @relation(fields: [productId], references: [id], onDelete: Restrict)
  specDefinition   SpecDefinition @relation(fields: [specDefinitionId], references: [id], onDelete: Restrict)

  @@unique([productId, specDefinitionId], map: "uq_product_specs")
  @@index([specDefinitionId, value], map: "idx_product_specs_value")
  @@map("product_specs")
}

model SpecScore {
  id               Int            @id @default(autoincrement())
  specDefinitionId Int            @map("spec_definition_id")
  value            String         @db.VarChar(200)
  score            Int
  benchmarkSource  String?        @map("benchmark_source") @db.VarChar(100)
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @default(now()) @map("updated_at")
  specDefinition   SpecDefinition @relation(fields: [specDefinitionId], references: [id], onDelete: Restrict)

  @@unique([specDefinitionId, value], map: "uq_spec_scores")
  @@index([specDefinitionId], map: "idx_spec_scores_definition")
  @@map("spec_scores")
}

model Seller {
  id          Int          @id @default(autoincrement())
  name        String       @db.VarChar(100)
  url         String       @db.VarChar(500)
  logoUrl     String?      @map("logo_url") @db.VarChar(500)
  trustScore  Int          @default(0) @map("trust_score")
  trustGrade  String?      @map("trust_grade") @db.VarChar(2)
  description String?      @db.VarChar(200)
  isActive    Boolean      @default(true) @map("is_active")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @default(now()) @map("updated_at")
  priceEntries PriceEntry[]
  cartItems    CartItem[]
  trustMetric  SellerTrustMetric?
  reviews      SellerReview[]
  crawlerJobs  CrawlerJob[]
  crawlerRuns  CrawlerRun[]
  productMappings ProductMapping[]
  fraudAlerts     FraudAlert[]
  buildParts      BuildPart[]
  pcBuildParts    PcBuildPart[]
  auctionBids     AuctionBid[]

  @@index([isActive], map: "idx_sellers_active")
  @@map("sellers")
}

model PriceEntry {
  id           Int           @id @default(autoincrement())
  productId    Int           @map("product_id")
  sellerId     Int           @map("seller_id")
  price        Int
  shippingCost Int           @default(0) @map("shipping_cost")
  shippingInfo String?       @map("shipping_info") @db.VarChar(100)
  productUrl   String        @map("product_url") @db.VarChar(1000)
  shippingFee  Int           @default(0) @map("shipping_fee")
  shippingType ShippingType  @default(PAID) @map("shipping_type")
  clickCount   Int           @default(0) @map("click_count")
  isAvailable  Boolean       @default(true) @map("is_available")
  crawledAt    DateTime?     @map("crawled_at")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @default(now()) @map("updated_at")
  product      Product       @relation(fields: [productId], references: [id], onDelete: Restrict)
  seller       Seller        @relation(fields: [sellerId], references: [id], onDelete: Restrict)
  fraudAlerts  FraudAlert[]

  @@unique([productId, sellerId], map: "uq_price_entries")
  @@index([productId, price], map: "idx_price_entries_product_price")
  @@map("price_entries")
}

model PriceHistory {
  id           Int       @id @default(autoincrement())
  productId    Int       @map("product_id")
  date         DateTime  @db.Date
  lowestPrice  Int       @map("lowest_price")
  averagePrice Int       @map("average_price")
  highestPrice Int       @map("highest_price")
  createdAt    DateTime  @default(now()) @map("created_at")
  product      Product   @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([productId, date], map: "uq_price_history")
  @@index([date(sort: Desc)], map: "idx_price_history_date")
  @@map("price_history")
}

model PriceAlert {
  id          Int       @id @default(autoincrement())
  userId      Int       @map("user_id")
  productId   Int       @map("product_id")
  targetPrice Int       @map("target_price")
  isTriggered Boolean   @default(false) @map("is_triggered")
  triggeredAt DateTime? @map("triggered_at")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  user        User      @relation(fields: [userId], references: [id], onDelete: Restrict)
  product     Product   @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([userId, productId], map: "uq_price_alerts")
  @@index([isActive, isTriggered], map: "idx_price_alerts_active")
  @@map("price_alerts")
}

model Address {
  id            Int      @id @default(autoincrement())
  userId        Int      @map("user_id")
  label         String   @db.VarChar(30)
  recipientName String   @map("recipient_name") @db.VarChar(50)
  phone         String   @db.VarChar(20)
  zipCode       String   @map("zip_code") @db.VarChar(10)
  address       String   @db.VarChar(255)
  addressDetail String?  @map("address_detail") @db.VarChar(255)
  isDefault     Boolean  @default(false) @map("is_default")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @map("updated_at")
  user          User     @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@map("addresses")
}

model CartItem {
  id              Int      @id @default(autoincrement())
  userId          Int      @map("user_id")
  productId       Int      @map("product_id")
  sellerId        Int?     @map("seller_id")
  selectedOptions String?  @map("selected_options") @db.Text
  quantity        Int      @default(1)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @map("updated_at")
  user            User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  product         Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  seller          Seller?  @relation(fields: [sellerId], references: [id], onDelete: Restrict)

  @@map("cart_items")
}

model Order {
  id             Int         @id @default(autoincrement())
  orderNumber    String      @map("order_number") @unique @db.VarChar(50)
  userId         Int         @map("user_id")
  status         OrderStatus
  totalAmount    Int         @map("total_amount")
  pointUsed      Int         @default(0) @map("point_used")
  finalAmount    Int         @map("final_amount")
  recipientName  String      @map("recipient_name") @db.VarChar(50)
  recipientPhone String      @map("recipient_phone") @db.VarChar(20)
  zipCode        String      @map("zip_code") @db.VarChar(10)
  address        String      @db.VarChar(255)
  addressDetail  String?     @map("address_detail") @db.VarChar(255)
  memo           String?
  version        Int         @default(1)
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @default(now()) @map("updated_at")
  user           User        @relation(fields: [userId], references: [id], onDelete: Restrict)
  orderItems     OrderItem[]
  payments       Payment[]
  reviews        Review[]
  sellerReviews  SellerReview[]

  @@map("orders")
}

model OrderItem {
  id              Int      @id @default(autoincrement())
  orderId         Int      @map("order_id")
  productId       Int      @map("product_id")
  sellerId        Int?     @map("seller_id")
  productName     String   @map("product_name") @db.VarChar(200)
  sellerName      String?  @map("seller_name") @db.VarChar(100)
  selectedOptions String?  @map("selected_options") @db.Text
  quantity        Int
  unitPrice       Int      @map("unit_price")
  totalPrice      Int      @map("total_price")
  isReviewed      Boolean  @default(false) @map("is_reviewed")
  createdAt       DateTime @default(now()) @map("created_at")
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@map("order_items")
}

model Payment {
  id         Int       @id @default(autoincrement())
  orderId    Int       @map("order_id")
  method     PaymentMethod
  amount     Int
  status     PaymentStatus
  paidAt     DateTime? @map("paid_at")
  refundedAt DateTime? @map("refunded_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  order      Order     @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@map("payments")
}

model Review {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  productId Int      @map("product_id")
  orderId   Int      @map("order_id")
  rating    Int
  content   String
  isBest    Boolean  @default(false) @map("is_best")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@unique([userId, orderId], map: "uq_reviews_user_order")
  @@index([productId], map: "idx_reviews_product")
  @@map("reviews")
}

model Wishlist {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  productId Int      @map("product_id")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([userId, productId], map: "uq_wishlists_user_product")
  @@map("wishlists")
}

model PointTransaction {
  id            Int       @id @default(autoincrement())
  userId        Int       @map("user_id")
  type          PointType
  amount        Int
  balance       Int
  description   String    @db.VarChar(200)
  referenceType String?   @map("reference_type") @db.VarChar(50)
  referenceId   Int?      @map("reference_id")
  expiresAt     DateTime? @map("expires_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  user          User      @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId], map: "idx_point_transactions_user")
  @@index([type], map: "idx_point_transactions_type")
  @@index([expiresAt], map: "idx_point_transactions_expires")
  @@map("point_transactions")
}

model Board {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(50)
  slug        String   @unique @db.VarChar(50)
  description String?  @db.VarChar(200)
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  posts       Post[]

  @@map("boards")
}

model Post {
  id           Int        @id @default(autoincrement())
  boardId      Int        @map("board_id")
  userId       Int        @map("user_id")
  title        String     @db.VarChar(200)
  content      String
  viewCount    Int        @default(0) @map("view_count")
  likeCount    Int        @default(0) @map("like_count")
  commentCount Int        @default(0) @map("comment_count")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @default(now()) @map("updated_at")
  deletedAt    DateTime?  @map("deleted_at")
  board        Board      @relation(fields: [boardId], references: [id], onDelete: Restrict)
  user         User       @relation(fields: [userId], references: [id], onDelete: Restrict)
  comments     Comment[]

  @@index([boardId], map: "idx_posts_board")
  @@index([userId], map: "idx_posts_user")
  @@index([createdAt(sort: Desc)], map: "idx_posts_created")
  @@map("posts")
}

model Comment {
  id        Int        @id @default(autoincrement())
  postId    Int        @map("post_id")
  userId    Int        @map("user_id")
  parentId  Int?       @map("parent_id")
  content   String
  createdAt DateTime   @default(now()) @map("created_at")
  deletedAt DateTime?  @map("deleted_at")
  post      Post       @relation(fields: [postId], references: [id], onDelete: Restrict)
  user      User       @relation(fields: [userId], references: [id], onDelete: Restrict)
  parent    Comment?   @relation("CommentTree", fields: [parentId], references: [id], onDelete: Restrict)
  children  Comment[]  @relation("CommentTree")

  @@index([postId], map: "idx_comments_post")
  @@index([parentId], map: "idx_comments_parent")
  @@map("comments")
}

model Inquiry {
  id          Int       @id @default(autoincrement())
  productId   Int       @map("product_id")
  userId      Int       @map("user_id")
  title       String    @db.VarChar(200)
  content     String
  isSecret    Boolean   @default(false) @map("is_secret")
  answer      String?
