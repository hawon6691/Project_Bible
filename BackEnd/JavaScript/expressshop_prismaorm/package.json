{
  "name": "javascript-express-prisma",
  "version": "0.1.0",
  "private": true,
  "description": "PBShop JavaScript Express Prisma ORM backend",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "test:e2e:critical": "node --env-file=.env --test test/e2e/critical.test.js",
    "test:e2e:contract": "node --env-file=.env --test test/e2e/contract.test.js",
    "test:e2e:admin-boundary": "node --env-file=.env --test test/e2e/admin-boundary.test.js",
    "test:e2e:security-regression": "node --env-file=.env --test test/e2e/security-regression.test.js",
    "test:e2e:platform": "node --env-file=.env --test test/e2e/critical.test.js test/e2e/contract.test.js test/e2e/admin-boundary.test.js",
    "db:docker:up": "docker compose -f ../../Database/docker/docker-compose.yml up -d postgres redis elasticsearch",
    "db:docker:down": "docker compose -f ../../Database/docker/docker-compose.yml down",
    "db:check": "powershell -ExecutionPolicy Bypass -File scripts/db-check.ps1",
    "db:init": "powershell -ExecutionPolicy Bypass -File scripts/db-init.ps1",
    "db:reset": "powershell -ExecutionPolicy Bypass -File scripts/db-reset.ps1",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1"
  },
  "devDependencies": {
    "prisma": "^6.5.0"
  }
}
